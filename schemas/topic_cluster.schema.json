    "topic_tags": {
      "items": {
        "type": "string"
      },
      "title": "Topic Tags",
      "type": "array"
    },
    "evidence_types": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Types",
      "type": "array"
    }
  },
  "required": [
    "topic_id",
    "cluster_fingerprint",
    "canonical_title",
    "anchor_item_id",
    "first_seen",
    "last_seen"
