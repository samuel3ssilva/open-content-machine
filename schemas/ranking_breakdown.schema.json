          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Floor Applied"
        },
        "anchor_id": {
          "title": "Anchor Id",
          "type": "string"
        },
        "anchor_text": {
          "title": "Anchor Text",
          "type": "string"
        },
        "inputs": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Inputs",
          "type": "object"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "weight": {
          "title": "Weight",
          "type": "integer"
        },
        "points": {
          "title": "Points",
          "type": "integer"
        }
      },
      "required": [
        "dimension",
        "raw_value",
        "effective_value",
        "anchor_id",
        "anchor_text",
        "rationale",
        "weight",
        "points"
      ],
      "title": "DimensionScore",
      "type": "object"
