        "expected",
        "predicted",
        "count"
      ],
      "title": "ConfusionCell",
      "type": "object"
    },
    "ErrorPattern": {
      "additionalProperties": false,
      "description": "An aggregated expected->predicted family error and how often it occurs.\n\nHolds only family labels and a count -- never a raw title -- so it is safe to\ncommit and to surface in reports.",
      "properties": {
        "expected": {
          "title": "Expected",
          "type": "string"
        },
        "predicted": {
          "title": "Predicted",
          "type": "string"
        },
        "count": {
          "title": "Count",
          "type": "integer"
        }
      },
      "required": [
        "expected",
        "predicted",
        "count"
      ],
      "title": "ErrorPattern",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Aggregate quality metrics over a labeled set. No raw titles by design.",
  "properties": {
    "n": {
      "title": "N",
      "type": "integer"
    },
    "high_confidence_precision": {
      "title": "High Confidence Precision",
      "type": "number"
    },
    "overall_classified_precision": {
