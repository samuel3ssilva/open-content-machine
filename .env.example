# Open Content Machine — environment template
# Copy to .env and fill in. NEVER commit .env. The demo works with NO keys at all
# (MockProvider + synthetic data).

# --- Model providers (all optional; leave empty for local/demo mode) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Privacy ---
# Salt used for deterministic pseudonymization of connection IDs.
# Generate your own (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
# Changing it changes every pseudonym; keep it local and private.
# CONTENT_MACHINE_SALT=

# --- Behavior ---
# Provider to use: mock | anthropic | openai  (default: mock)
# CONTENT_MACHINE_PROVIDER=mock
# Directory for private local data (default: ./data/private)
# CONTENT_MACHINE_DATA_DIR=./data/private
